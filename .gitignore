# =========================
outputs/videos/
outputs/temp/
outputs/cache/

results/videos/*.mp4
results/videos/*.avi
results/videos/*.mov
results/videos/*.mkv

# Keep important CSV/XLSX/JPG outputs
!results/benchmark/*.csv
!results/benchmark/*.xlsx
!results/visualizations/*.jpg
!results/visualizations/*.png

# =========================
# Logs
# =========================
*.log
logs/
data/raw/*
!data/raw/.gitkeep
