# Kaggle temporary folders
# =========================
kaggle/working/
kaggle/input/
working/
input/

# =========================
# Raw data / datasets
# =========================
data/raw/*
data/processed/*
data/sample_videos/*

!data/raw/.gitkeep
!data/processed/.gitkeep
!data/sample_videos/.gitkeep

# =========================
# Large videos
# =========================
*.mp4
*.avi
*.mov
*.mkv
*.webm

# Keep screenshots/images
!*.jpg
!*.jpeg
!*.png

# =========================
# Model weights
# =========================
*.pt
*.pth
*.ckpt
*.onnx
*.h5
*.weights

# =========================
