*.pyc
*.pyo
*.pyd
*.py[cod]
*$py.class

.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# =========================
# OS / editor
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/

